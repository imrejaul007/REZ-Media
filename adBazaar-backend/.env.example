# Environment Variables for AdBazaar Backend

# Server
PORT=4085
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/adbazaar

# Redis
REDIS_URL=redis://localhost:6379

# Internal Service Token
INTERNAL_SERVICE_TOKEN=your-secret-token-here

# Service URLs
PAYMENT_SERVICE_URL=http://localhost:4001
AUTH_URL=http://localhost:3000
NOTIFICATION_URL=http://localhost:4004
ANALYTICS_URL=http://localhost:4006
DOOH_INTEL_URL=http://localhost:4080
ATTRIBUTION_URL=http://localhost:4081
INTELLIGENCE_URL=http://localhost:3001
RFM_SERVICE_URL=http://localhost:4055
PRICING_ENGINE_URL=http://localhost:4016

# Platform Settings
PLATFORM_FEE_PERCENT=30
MIN_PAYOUT=1000
PAYOUT_SCHEDULE=monthly
