# DOOH Screen App - Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# DOOH Service API URL (REQUIRED)
# The backend service URL for screen registration and management
EXPO_PUBLIC_DOOH_API_URL=https://dooh-api.rezapp.com

# Internal service token for API authentication
# Must match the token configured in rez-dooh-service
INTERNAL_SERVICE_TOKEN=your-internal-service-token-here

# DOOH API key for screen endpoints
DOOH_API_KEY=your-dooh-api-key-here

# =============================================================================
# SUPABASE CONFIGURATION (if using)
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=https://rezapp.com,https://www.rezapp.com

# DOOH Server URL (for screen configuration)
NEXT_PUBLIC_DOOH_SERVER=https://dooh.rezapp.com

# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# 1. Variables prefixed with NEXT_PUBLIC_ are exposed to the client
#    Only include non-sensitive configuration here
#
# 2. API URLs and tokens are sensitive - treat them carefully
#
# 3. Never commit .env files to version control
#
