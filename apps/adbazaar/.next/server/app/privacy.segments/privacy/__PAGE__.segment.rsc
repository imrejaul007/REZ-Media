"children":[["$","h2",null,{"className":"text-base font-semibold text-white mb-2","children":"5. Data Retention"}],["$","p",null,{"children":"We retain your data for as long as your account is active or as required by law. You may request deletion of your account and associated data by contacting us."}]]}],["$","section",null,{"children":[["$","h2",null,{"className":"text-base font-semibold text-white mb-2","children":"6. Security"}],["$","p",null,{"children":"We implement industry-standard security measures including TLS encryption, Supabase row-level security, and access controls. No system is completely secure; we encourage you to use a strong password."}]]}],["$","section",null,{"children":[["$","h2",null,{"className":"text-base font-semibold text-white mb-2","children":"7. Your Rights"}],["$","p",null,{"children":["You have the right to access, correct, or delete your personal data. Contact us at"," ",["$","a",null,{"href":"mailto:privacy@adBazaar.in","style":{"color":"#f59e0b"},"children":"privacy@adBazaar.in"}]," ","to exercise these rights."]}]]}],["$","section",null,{"children":[["$","h2",null,{"className":"text-base font-semibold text-white mb-2","children":"8. Contact"}],["$","p",null,{"children":["For privacy questions, email"," ",["$","a",null,{"href":"mailto:privacy@adBazaar.in","style":{"color":"#f59e0b"},"children":"privacy@adBazaar.in"}],"."]}]]}]]}]]}]}],null,["$","$L2",null,{"children":["$","$3",null,{"name":"Next.MetadataOutlet","children":"$@4"}]}]]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"zpsfA_u7BfUqYCRvK0k9q"}
