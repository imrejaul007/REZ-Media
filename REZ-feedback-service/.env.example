# Feedback Service - Environment Variables

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Internal service token (REQUIRED)
INTERNAL_SERVICE_TOKEN=your-secure-random-token-here

# JSON map of service tokens
INTERNAL_SERVICE_TOKENS_JSON={"order-service":"token1","app-service":"token2"}

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# Port
PORT=4010

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-feedback

# Redis
REDIS_URL=redis://localhost:6379

# Sentry
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# ReZ Mind Integration
REZ_MIND_URL=http://localhost:4000
REZ_MIND_API_KEY=your-api-key

# Allowed CORS origins
ALLOWED_ORIGINS=https://rezapp.com,https://www.rezapp.com

# Logging
LOG_LEVEL=info

# Node environment
NODE_ENV=development

# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# 1. INTERNAL_SERVICE_TOKEN is REQUIRED
# 2. Generate with: openssl rand -hex 32
#
