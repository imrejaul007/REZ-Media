# ReZ Support Tools Hub - Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=4057
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-support-hub

# Redis
REDIS_URL=redis://localhost:6379

# Internal Service Token (for service-to-service communication)
INTERNAL_SERVICE_TOKEN=change-me-in-production

# Zendesk Configuration
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=your-email@company.com
ZENDESK_API_TOKEN=your-zendesk-api-token

# Freshdesk Configuration
FRESHDESK_DOMAIN=your-domain.freshdesk.com
FRESHDESK_API_KEY=your-freshdesk-api-key

# Intercom Configuration
INTERCOM_ACCESS_TOKEN=your-intercom-access-token
INTERCOM_CLIENT_ID=your-intercom-client-id
INTERCOM_CLIENT_SECRET=your-intercom-client-secret
INTERCOM_WEBHOOK_SECRET=your-intercom-webhook-secret

# Sync Configuration
SYNC_INTERVAL_MINUTES=5
SYNC_BATCH_SIZE=100
WEBHOOK_CONCURRENT_LIMIT=10

# ReZ Platform Integration
REZ_API_BASE_URL=http://localhost:3000
REZ_API_KEY=your-rez-api-key

# CORS
CORS_ORIGIN=*
