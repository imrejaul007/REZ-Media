# Service Configuration
NODE_ENV=development
PORT=3005
SERVICE_NAME=rez-ads
LOG_LEVEL=info

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-ads

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-jwt-secret-change-in-production-min-32-chars

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Internal Service Communication
INTERNAL_SERVICE_TOKENS_JSON={"rez-auth":"token-here","rez-intent":"token-here","rez-pricing":"token-here"}

# Ad Serving Configuration
AD_SERVER_URL=http://localhost:3005
MAX_BID_CPM=10.00
MIN_BID_CPM=0.01
DEFAULT_BID_CPM=1.00

# Bidding Engine
PRICING_ENGINE_URL=http://localhost:4006

# Fraud Detection
FRAUD_CHECK_ENABLED=true
FRAUD_CLICK_THRESHOLD=5
FRAUD_WINDOW_MINUTES=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
