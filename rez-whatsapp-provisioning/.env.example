# Server Configuration
PORT=3005
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez_whatsapp_provisioning
MONGODB_USER=
MONGODB_PASSWORD=

# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret_here
TWILIO_WHATSAPP_SANDBOX_NUMBER=+14155238886

# Webhook Configuration
WEBHOOK_BASE_URL=https://your-domain.com
INBOUND_WEBHOOK_PATH=/webhooks/whatsapp/inbound
STATUS_WEBHOOK_PATH=/webhooks/whatsapp/status
OUTBOUND_WEBHOOK_PATH=/webhooks/whatsapp/outbound

# Internal Service Authentication
INTERNAL_SERVICE_TOKENS_JSON={"rez-platform":"your-service-token"}

# Redis Configuration (optional, for caching and rate limiting)
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Security
JWT_SECRET=your-jwt-secret-min-32-chars-here
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Provisioning Limits
MAX_PHONE_NUMBERS_PER_MERCHANT=10
MAX_TEMPLATES_PER_MERCHANT=50
