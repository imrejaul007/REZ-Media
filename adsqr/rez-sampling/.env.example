# ===========================================
# AdsQr - QR Campaign Platform
# ===========================================

# ===========================================
# App URLs
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3005
NEXT_PUBLIC_API_URL=http://localhost:3005/api

# ===========================================
# Supabase
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===========================================
# REZ Ecosystem Integration
# ===========================================

# REZ Wallet Service
REZ_WALLET_URL=http://localhost:4002
REZ_WALLET_API_KEY=

# REZ Economic Engine (REE)
REE_API_URL=http://localhost:4006
REE_API_KEY=

# REZ Gamification
REZ_GAMIFICATION_URL=http://localhost:3004
REZ_GAMIFICATION_API_KEY=

# REZ Analytics
REZ_ANALYTICS_URL=http://localhost:4001
REZ_ANALYTICS_API_KEY=

# REZ Marketing (for broadcasts)
REZ_MARKETING_URL=http://localhost:4000
REZ_MARKETING_API_KEY=

# ===========================================
# Fraud Detection
# ===========================================
FRAUD_API_URL=https://fraud.rez.money
FRAUD_API_KEY=

# ===========================================
# Brand Coins (Rewards)
# ===========================================
BRAND_COIN_ISSUER_ID=
BRAND_COIN_SECRET=

# ===========================================
# AI Services
# ===========================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ===========================================
# Database (PostgreSQL for analytics)
# ===========================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/adsqr

# ===========================================
# QR Code Generation
# ===========================================
QR_BASE_URL=https://adsqr.rez.money
QR_SLUG_LENGTH=8

# ===========================================
# Campaign Defaults
# ===========================================
DEFAULT_COIN_REWARD=10
MAX_COIN_REWARD=100
MIN_CAMPAIGN_BUDGET=500

# ===========================================
# Feature Flags
# ===========================================
ENABLE_QR_TRACKING=true
ENABLE_ATTRIBUTION=true
ENABLE_RETARGETING=true
ENABLE_AI_OPTIMIZATION=false
