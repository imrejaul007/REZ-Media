# ===========================================
# REZ Owner Service
# ===========================================
# Unified Owner Dashboard API - Aggregates all inventory sources

# ===========================================
# Server
# ===========================================
PORT=4010
NODE_ENV=development

# ===========================================
# Authentication
# ===========================================
JWT_SECRET=your-jwt-secret
INTERNAL_SERVICE_TOKENS={"rez-merchant":"token","adBazaar":"token","adsqr":"token","dooh":"token"}

# ===========================================
# MongoDB
# ===========================================
MONGODB_URI=mongodb://localhost:27017/rez-owner

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# Connected Services
# ===========================================

# AdBazaar Service
ADBAZAAR_API_URL=http://localhost:3001
ADBAZAAR_API_KEY=

# DOOH Service
DOOH_API_URL=http://localhost:3005
DOOH_API_KEY=

# AdsQr / Sampling Service
ADSQR_API_URL=http://localhost:3006
ADSQR_API_KEY=

# In-App Ad Network
INAPP_AD_API_URL=http://localhost:3007
INAPP_AD_API_KEY=

# REZ Analytics
ANALYTICS_API_URL=http://localhost:4001
ANALYTICS_API_KEY=

# REZ Wallet
WALLET_API_URL=http://localhost:4002
WALLET_API_KEY=

# REZ Merchant
MERCHANT_API_URL=http://localhost:4003
MERCHANT_API_KEY=

# ===========================================
# Feature Flags
# ===========================================
ENABLE_DOOH=true
ENABLE_QR_CAMPAIGNS=true
ENABLE_INAPP_ADS=true
ENABLE_UNIFIED_EARNINGS=true
ENABLE_CROSS_PROMOTION=true
