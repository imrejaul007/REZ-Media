# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-checkout

# Redis
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Service Configuration
API_VERSION=v1
ENABLE_CORS=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Payment Gateway Configuration
PAYMENT_GATEWAY_URL=http://localhost:4001
PAYMENT_GATEWAY_API_KEY=your-payment-gateway-api-key

# Fraud Detection
FRAUD_CHECK_ENABLED=true
MAX_ORDERS_PER_HOUR=10
MAX_ORDER_VALUE=100000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# UPI Configuration
PREFERRED_PAYMENT_METHODS=UPI,CARD,NETBANKING,WALLET,COD

# Analytics
ENABLE_ANALYTICS=true
