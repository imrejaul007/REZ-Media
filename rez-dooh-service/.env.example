# DOOH Service - Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Internal service token (REQUIRED - no fallback)
# Generate a secure random token for service-to-service auth
INTERNAL_SERVICE_TOKEN=your-secure-random-token-here

# JSON map of service tokens for different services
# Format: {"service-name": "token"}
INTERNAL_SERVICE_TOKENS_JSON={"merchant-service":"token1","analytics-service":"token2"}

# DOOH API key for screen authentication
DOOH_API_KEY=your-dooh-api-key-here

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# Server URL (defaults to https://dooh.rezapp.com)
DOOH_SERVER_URL=https://dooh.rezapp.com

# Port to run the service on (defaults to 4018)
PORT=4018

# ReZ Mind integration
REZ_MIND_ENDPOINT=https://rezmind.rezapp.com
REZ_MIND_API_KEY=your-rezmind-api-key

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=https://rezapp.com,https://www.rezapp.com,https://dooh.rezapp.com

# Node environment
NODE_ENV=development

# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# 1. INTERNAL_SERVICE_TOKEN is REQUIRED - the service will throw an error at
#    startup if not set. There is no fallback token anymore.
#
# 2. Use strong random tokens (minimum 32 characters)
#    Generate with: openssl rand -hex 32
#
# 3. Rotate tokens regularly and never commit .env to version control
#
# 4. Each service should have its own token in INTERNAL_SERVICE_TOKENS_JSON
#
