# ===========================================
# REZ Pricing Engine
# ===========================================
# AI-Powered Dynamic Pricing for Commerce Media Exchange

# ===========================================
# Server
# ===========================================
PORT=3008
NODE_ENV=development

# ===========================================
# MongoDB
# ===========================================
MONGODB_URI=mongodb://localhost:27017/rez-pricing

# ===========================================
# Redis (for caching & rate limiting)
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# External Services
# ===========================================

# REZ Economic Engine (REE)
REE_API_URL=http://localhost:4006
REE_API_KEY=

# REZ Analytics
ANALYTICS_API_URL=http://localhost:4001
ANALYTICS_API_KEY=

# Weather API (for weather-based pricing)
WEATHER_API_KEY=
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# ===========================================
# AI Services
# ===========================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ===========================================
# Pricing Config
# ===========================================

# Default surge caps by ad type
DEFAULT_BANNER_CAP=5
DEFAULT_SEARCH_CAP=6
DEFAULT_PUSH_CAP=4
DEFAULT_WHATSAPP_CAP=3
DEFAULT_EMAIL_CAP=2
DEFAULT_DOOH_CAP=8
DEFAULT_QR_CAP=5

# Minimum campaign spend (in rupees)
MIN_BANNER_SPEND=500
MIN_PUSH_SPEND=300
MIN_WHATSAPP_SPEND=1000
MIN_DOOH_SPEND=3000
MIN_OFFLINE_SPEND=5000

# Quality score weights
QS_CTR_WEIGHT=0.25
QS_CONVERSION_WEIGHT=0.25
QS_QR_ENGAGEMENT_WEIGHT=0.15
QS_FEEDBACK_WEIGHT=0.10
QS_RELEVANCE_WEIGHT=0.15
QS_LANDING_WEIGHT=0.10

# ===========================================
# Feature Flags
# ===========================================
ENABLE_LIQUIDATION=true
ENABLE_SURGE_PRICING=true
ENABLE_QUALITY_SCORE=true
ENABLE_AI_CONFIDENCE=true
