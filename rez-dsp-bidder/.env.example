# Service Configuration
PORT=4061
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/dsp_bidder_dev

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
INTERNAL_SERVICE_TOKEN=your-internal-service-token-here

# DSP Configuration
