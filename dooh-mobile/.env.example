# DOOH Mobile App - Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# DOOH Service API URL (REQUIRED)
# The backend service URL for screen management
EXPO_PUBLIC_DOOH_API_URL=https://dooh-api.rezapp.com

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# Supabase (if using for auth)
# EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# 1. Variables prefixed with EXPO_PUBLIC_ are exposed in the app bundle
#    Only include non-sensitive configuration here
#
# 2. For sensitive data like tokens, use Expo SecureStore
#
# 3. API keys for screen authentication should be:
#    - Stored in SecureStore on the device
#    - Retrieved at runtime, not hardcoded
#
# 4. Never commit .env files to version control
#
