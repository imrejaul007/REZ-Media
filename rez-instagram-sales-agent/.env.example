# Server Configuration
PORT=4091
NODE_ENV=development

# Logging
LOG_LEVEL=info

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://rez.shop

# Instagram API Configuration
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_VERIFY_TOKEN=your_webhook_verify_token
INSTAGRAM_PAGE_ID=your_facebook_page_id

# WhatsApp Business Configuration
WHATSAPP_BUSINESS_NUMBER=1234567890
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token

# Product & Shop Configuration
LINK_IN_BIO_URL=https://rez.shop
SHOP_URL=https://rez.shop
PRODUCT_URL_TEMPLATE=https://rez.shop/product/{id}
COLLECTION_URL_TEMPLATE=https://rez.shop/collection/{slug}
CART_URL=https://rez.shop/cart
CHECKOUT_URL=https://rez.shop/checkout

# Internal Service Communication
INTERNAL_SERVICE_TOKENS_JSON={"rez-payment-service":"token","rez-order-service":"token"}

# Redis Configuration (optional - for session persistence)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# MongoDB Configuration (optional - for lead persistence)
MONGODB_URI=mongodb://localhost:27017/rez-instagram

# UTM & Analytics
UTM_SOURCE=instagram
UTM_MEDIUM=dm

# Business Rules
FREE_SHIPPING_THRESHOLD=50
STANDARD_SHIPPING_DAYS=5
EXPRESS_SHIPPING_DAYS=2
EXPRESS_SHIPPING_COST=12.99
TAX_RATE=0.08

# Follow-up Configuration
MAX_FOLLOW_UPS=3
ABANDONED_CART_DELAY_HOURS=2
PROMO_CODE_EXPIRY_HOURS=48

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Webhook Configuration
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY_MS=5000

# Security
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here
