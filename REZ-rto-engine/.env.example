# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez_rto_engine

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Internal Service Token (JSON map for service-to-service auth)
INTERNAL_SERVICE_TOKENS_JSON={"rez-checkout":"secret-token-1","rez-payment":"secret-token-2"}

# Server Configuration
PORT=3008
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Risk Engine Configuration
RISK_THRESHOLD_LOW=30
RISK_THRESHOLD_MEDIUM=60
RISK_THRESHOLD_HIGH=100

# Device Fingerprint Configuration
FINGERPRINT_SECRET=your-fingerprint-secret-key

# Address Validation Configuration
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# External Service URLs
DECISION_SERVICE_URL=http://localhost:3009
CHECKOUT_SERVICE_URL=http://localhost:3010
