# WhatsApp Commerce - Environment Variables

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

INTERNAL_SERVICE_TOKEN=your-secure-random-token-here
INTERNAL_SERVICE_TOKENS_JSON={"order-service":"token1","product-service":"token2"}

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

PORT=4030
MONGODB_URI=mongodb://localhost:27017/rez-whatsapp
NODE_ENV=development

# =============================================================================
# SECURITY NOTES
# =============================================================================
# Generate token: openssl rand -hex 32
