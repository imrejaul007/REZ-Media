# REZ Voice Billing Service - Environment Variables Example
# Copy this file to .env and fill in your values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=4005
HOST=0.0.0.0

# ============================================
# MONGODB CONFIGURATION
# ============================================
MONGODB_URI=mongodb://localhost:27017/rez-voice-billing
# MONGODB_USER=your_username
# MONGODB_PASSWORD=your_password

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# ============================================
# INTERNAL SERVICE AUTHENTICATION
# ============================================
# JSON map of service tokens: {"service-name":"token"}
INTERNAL_SERVICE_TOKENS_JSON={"voice-billing":"your-voice-billing-token","wallet-service":"your-wallet-token"}
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============================================
# REZ MEDIA WALLET INTEGRATION
# ============================================
# Base URL for the REZ Media Wallet service
WALLET_SERVICE_URL=http://localhost:4002
# Token for internal service-to-service communication
WALLET_SERVICE_TOKEN=your-wallet-service-token

# ============================================
# BILLING CONFIGURATION
# ============================================
# Default rate per minute (INR)
DEFAULT_RATE_PER_MINUTE=0.05
# Billing interval in seconds (60 = bill by minute)
BILLING_INTERVAL_SECONDS=60
# Minimum charge in seconds (calls shorter than this are not charged)
MINIMUM_CHARGE_SECONDS=1
# Free call duration in seconds (0 = no free calls)
FREE_CALL_DURATION_SECONDS=0

# ============================================
# CALL CONFIGURATION
# ============================================
# Maximum call duration in seconds (3600 = 1 hour)
MAX_CALL_DURATION_SECONDS=3600
# Call timeout in seconds
CALL_TIMEOUT_SECONDS=30

# ============================================
# ANALYTICS CONFIGURATION
# ============================================
# Batch size for aggregation jobs
AGGREGATION_BATCH_SIZE=1000
# How long to retain analytics data (days)
ANALYTICS_RETENTION_DAYS=90

# ============================================
# QUEUE CONFIGURATION
# ============================================
# Number of concurrent billing jobs
QUEUE_CONCURRENCY=5

# ============================================
# RATE LIMITING
# ============================================
# Rate limit window in milliseconds
RATE_LIMIT_WINDOW_MS=60000
# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
