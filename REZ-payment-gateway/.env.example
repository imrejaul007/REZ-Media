# REZ Payment Gateway

PORT=4010
NODE_ENV=production

# Razorpay
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez_payments

# Redis
REDIS_URL=redis://localhost:6379

# Wallet Service
WALLET_SERVICE_URL=http://localhost:4001

# Internal Auth
INTERNAL_SERVICE_TOKENS_JSON={"payment-gateway":"token"}
