# REZ Payment Gateway Environment Variables

# Server Configuration
PORT=4010
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-payment-gateway

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_FUND_ACCOUNT_ID=your_fund_account_id

# Redis (optional, for production caching)
REDIS_URL=redis://localhost:6379

# Internal Service Authentication
INTERNAL_SERVICE_TOKEN=generate_secure_token_here
INTERNAL_SERVICE_TOKENS_JSON={"payment-gateway":"token"}
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# Wallet Service (for internal service calls)
WALLET_SERVICE_URL=http://localhost:4002

# Logging
LOG_LEVEL=info
