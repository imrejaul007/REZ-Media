# Server Configuration
PORT=4051
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/woocommerce-connector

# Redis
REDIS_URL=redis://localhost:6379

# Internal Service Token (shared across RABTUL services)
INTERNAL_SERVICE_TOKEN=your-internal-service-token-here
INTERNAL_SERVICE_TOKENS_JSON={"service-name":"token"}

# WooCommerce
WOOCOMMERCE_WEBHOOK_SECRET=your-webhook-secret-here

# ReZ Platform Services (optional - for internal communication)
REZ_IDENTITY_SERVICE_URL=http://localhost:4001
REZ_ORDER_SERVICE_URL=http://localhost:4003
REZ_PRODUCT_SERVICE_URL=http://localhost:4005

# Logging
LOG_LEVEL=info
