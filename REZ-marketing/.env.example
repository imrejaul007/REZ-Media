# ============================================================
# REZ Marketing Platform - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in the values
# NEVER commit .env files with real credentials to version control

# ──────────────────────────────────────────────────────────────
# Application Configuration
# ──────────────────────────────────────────────────────────────

# Node environment (production | development)
NODE_ENV=production

# Server port (default: 4000 for local, 10000 for Render)
PORT=4000

# CORS allowed origins (comma-separated for multiple)
CORS_ORIGIN=https://rez.money,https://app.rez.money

# ──────────────────────────────────────────────────────────────
# Database - MongoDB
# ──────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017/rez_marketing
# Docker: mongodb://mongo:27017/rez_marketing
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/rez_marketing

MONGODB_URI=mongodb://localhost:27017/rez_marketing

# ──────────────────────────────────────────────────────────────
# Redis / BullMQ Queue Backend
# ──────────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Docker: redis://redis:6379
# Render Redis: redis://redis-xxxx.up.railway.app:6379
# Authenticated: redis://:password@localhost:6379

REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────────────────────
# Service-to-Service Authentication (REQUIRED)
# ──────────────────────────────────────────────────────────────
# Option 1: JSON map of service names to tokens (RECOMMENDED)
# Format: {"service-name": "token-value", "another-service": "token2"}
# The x-internal-service header determines which token to validate
#
# Example tokens (generate with: openssl rand -base64 32):
# {"rez-gateway": "k8s@GATEWAY#2024!", "rez-analytics": "An4lyt1cs!Sec"}

INTERNAL_SERVICE_TOKENS_JSON={"rez-gateway": "CHANGE_ME", "rez-analytics": "CHANGE_ME"}

# Option 2: Legacy single token (for backward compatibility only)
# INTERNAL_SERVICE_TOKEN=CHANGE_ME_LEGACY_TOKEN

# ──────────────────────────────────────────────────────────────
# Sentry Error Tracking (Optional but recommended)
# ──────────────────────────────────────────────────────────────
# Get your DSN from https://sentry.io/settings/<org>/projects/<project>/keys/
# Format: https://<key>@o<org>.ingest.sentry.io/<project>

SENTRY_DSN=

# ──────────────────────────────────────────────────────────────
# WhatsApp / Twilio Configuration
# ──────────────────────────────────────────────────────────────
# Get credentials from https://console.twilio.com

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+15551234567

# ──────────────────────────────────────────────────────────────
# SMS Configuration (Twilio or MSG91)
# ──────────────────────────────────────────────────────────────
TWILIO_PHONE_NUMBER=+15551234567

# OR MSG91 (Indian SMS provider)
# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=REZSMS

# ──────────────────────────────────────────────────────────────
# Email / SMTP Configuration
# ──────────────────────────────────────────────────────────────
# SMTP settings for transactional emails (Zoho, SendGrid, Mailgun, AWS SES)

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@rez.money
SMTP_PASS=CHANGE_ME
EMAIL_FROM=REZ <noreply@rez.money>

# AWS SES alternative (uncomment and fill):
# SES_REGION=ap-south-1
# AWS_SES_SMTP_USER=your-ses-smtp-user
# AWS_SES_SMTP_PASS=your-ses-smtp-pass

# ──────────────────────────────────────────────────────────────
# Push Notifications - Firebase (Optional)
# ──────────────────────────────────────────────────────────────
# FCM_SERVER_KEY=

# ──────────────────────────────────────────────────────────────
# Intent Capture - REZ Intent Graph Service
# ──────────────────────────────────────────────────────────────
# RTMN Commerce Memory endpoint for intent capture
INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com

# ──────────────────────────────────────────────────────────────
# WhatsApp Meta Graph API (Optional)
# ──────────────────────────────────────────────────────────────
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=rez_mkt_verify

# ──────────────────────────────────────────────────────────────
# Frontend URL (for email links, unsubscribe, etc.)
# ──────────────────────────────────────────────────────────────
FRONTEND_URL=https://app.rez.money

# ──────────────────────────────────────────────────────────────
# Docker Compose Local Development Overrides
# Uncomment and adjust ports as needed
# ──────────────────────────────────────────────────────────────

# MongoDB port mapping
# MONGO_PORT=27017

# Redis port mapping
# REDIS_PORT=6379

# Prometheus metrics port (for monitoring profile)
# PROMETHEUS_PORT=9090

# Grafana port (for monitoring profile)
# GRAFANA_PORT=3001
# GRAFANA_PASSWORD=CHANGE_ME

# Application port mapping
# APP_PORT=4000
