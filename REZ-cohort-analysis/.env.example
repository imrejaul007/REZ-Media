# REZ Cohort Analysis Service Environment Variables
# Copy to .env and configure

# Server
PORT=4027
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/rez-cohort-analysis

# Cache (Optional)
REDIS_URL=redis://localhost:6379

# Security
INTERNAL_SERVICE_TOKEN=change-me-in-production

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=debug
