# Instagram/Meta API Configuration
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# Webhook Configuration
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
WEBHOOK_CALLBACK_URL=https://your-domain.com/webhook/instagram

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez-instagram-bridge

# Redis Configuration
REDIS_URL=redis://localhost:6379

# REZ Orchestrator Configuration
ORCHESTRATOR_URL=http://localhost:4000
INTERNAL_SERVICE_TOKENS_JSON={"instagram-bridge":"your-instagram-bridge-token"}

# WhatsApp Handoff Configuration
WHATSAPP_BRIDGE_URL=http://localhost:4091

# Server Configuration
PORT=4090
NODE_ENV=development

# Logging
LOG_LEVEL=info
