# =============================================================================
# REZ Communications Platform - Environment Configuration
# Central Marketing Hub for REZ-Media apps
# =============================================================================

# =============================================================================
# CORE SETTINGS
# =============================================================================

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Allowed CORS origins (comma-separated, or use wildcard patterns)
ALLOWED_ORIGIN=http://localhost:3000

# =============================================================================
# AUTHENTICATION - Internal Service Tokens
# =============================================================================

# JSON map of service names to their tokens
# Format: {"service-name":"token","another-service":"token2"}
# REZ-Media apps should use this header: X-Internal-Token: <token>
INTERNAL_SERVICE_TOKENS_JSON={"communications-platform":"your-platform-token","ads-service":"ads-token","gamification":"gamification-token","rez-agent-os":"agent-token"}

# =============================================================================
# EMAIL CONFIGURATION (SendGrid or AWS SES)
# =============================================================================

EMAIL_PROVIDER=mock
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@rez.io
EMAIL_FROM_NAME=REZ
EMAIL_TRACKING_ENABLED=false

# AWS SES (alternative to SendGrid)
# EMAIL_PROVIDER=ses
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# SES_FROM_EMAIL=noreply@rez.io

# =============================================================================
# SMS CONFIGURATION (Twilio)
# =============================================================================

SMS_PROVIDER=mock
# SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# =============================================================================
# WHATSAPP CONFIGURATION (Twilio or WhatsApp Business API)
# =============================================================================

WHATSAPP_PROVIDER=mock
# WHATSAPP_PROVIDER=twilio
WHATSAPP_FROM_NUMBER=+1234567890

# WhatsApp Business API (alternative to Twilio)
# WHATSAPP_PROVIDER=whatsapp-business
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
# WHATSAPP_APP_SECRET=your-app-secret
# WHATSAPP_VERIFY_TOKEN=your-verify-token-for-webhook

# WhatsApp Web (development only)
# WHATSAPP_PROVIDER=whatsapp-web
WHATSAPP_SESSION_PATH=./whatsapp-sessions

# WhatsApp Auto-Reply (optional)
WHATSAPP_AUTO_REPLY=false
WHATSAPP_AUTO_REPLY_MESSAGE=Thanks for your message! We will respond shortly.

# =============================================================================
# PUSH NOTIFICATIONS (Firebase Cloud Messaging)
# =============================================================================

PUSH_PROVIDER=mock
# PUSH_PROVIDER=firebase
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# =============================================================================
# REDIS QUEUE CONFIGURATION
# =============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis connection URL (alternative to individual settings)
# REDIS_URL=redis://localhost:6379

# =============================================================================
# RATE LIMITING
# =============================================================================

# Requests per minute per service
RATE_LIMIT_RPM=1000

# Burst size for rate limiting
RATE_LIMIT_BURST=100

# =============================================================================
# WEBHOOK CONFIGURATION
# =============================================================================

# Webhook handlers (forward events to external services)
# WEBHOOK_HANDLER_URL_1=https://your-service.com/webhooks/rez
# WEBHOOK_HANDLER_EVENTS_1=message.received,status.delivered,email.opened
# WEBHOOK_HANDLER_URL_2=https://analytics.rez.io/events
# WEBHOOK_HANDLER_EVENTS_2=*

# =============================================================================
# REZ-AGENT-OS INTEGRATION
# =============================================================================

# Enable AI agent integration
AGENTS_ENABLED=true

# Auto-execute agent recommendations
AGENTS_AUTO_EXECUTE=false

# Insight retention period (days)
AGENTS_INSIGHT_RETENTION_DAYS=90

# Agent OS service URL
# AGENT_OS_URL=http://localhost:4005

# =============================================================================
# CAMPAIGN SETTINGS
# =============================================================================

# Default throttle rate for campaigns (messages per minute)
CAMPAIGN_THROTTLE_PER_MINUTE=100

# Campaign execution timeout (ms)
CAMPAIGN_EXECUTION_TIMEOUT=300000

# =============================================================================
# TEMPLATE SETTINGS
# =============================================================================

# Template cache TTL (seconds)
TEMPLATE_CACHE_TTL=3600

# =============================================================================
# DATABASE (for storing campaigns, insights, etc.)
# =============================================================================

# MongoDB
# MONGODB_URI=mongodb://localhost:27017/communications
# MONGODB_USER=
# MONGODB_PASSWORD=

# =============================================================================
# SERVICE URLs (for internal service-to-service communication)
# =============================================================================

AUTH_SERVICE_URL=http://localhost:4002
USER_SERVICE_URL=http://localhost:4003
MERCHANT_SERVICE_URL=http://localhost:4004
NOTIFICATIONS_HUB_URL=http://localhost:4009

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Datadog (optional)
# DATADOG_API_KEY=your-datadog-api-key
# DATADOG_ENABLED=false

# Sentry (optional)
# SENTRY_DSN=your-sentry-dsn
# SENTRY_ENVIRONMENT=development

# =============================================================================
# SECURITY
# =============================================================================

# JWT Secret (for user authentication, if needed)
# JWT_SECRET=your-jwt-secret

# Encryption key for sensitive data
# ENCRYPTION_KEY=your-32-character-encryption-key

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable debug logging for webhooks
WEBHOOK_DEBUG_LOGGING=false

# Mock delay for simulating network latency (ms)
# MOCK_DELAY=0
