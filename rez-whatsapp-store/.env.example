# Server Configuration
PORT=4005
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-whatsapp-store

# Redis
REDIS_URL=redis://localhost:6379

# Internal Service Tokens (JSON map format)
INTERNAL_SERVICE_TOKENS_JSON={"whatsapp-store":"token123","payment-service":"token456","wallet-service":"token789","order-service":"token012"}

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Twilio WhatsApp Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM_NUMBER=+14155238886

# WhatsApp Business API
WHATSAPP_BUSINESS_ACCOUNT_ID=WBAxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=your-app-secret

# Razorpay (for UPI/Card payments)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Service URLs (for internal communication)
WALLET_SERVICE_URL=http://localhost:4002
PAYMENT_SERVICE_URL=http://localhost:4003
ORDER_SERVICE_URL=http://localhost:4004
USER_SERVICE_URL=http://localhost:4001
COMMUNICATIONS_URL=http://localhost:3000

# WhatsApp Store Settings
STORE_NAME=REZ Store
DEFAULT_CURRENCY=INR
DEFAULT_LANGUAGE=en

# Delivery Settings
DEFAULT_DELIVERY_FEE=30
FREE_DELIVERY_THRESHOLD=499
MAX_DELIVERY_RADIUS_KM=10

# Cart Settings
CART_EXPIRY_HOURS=24
MIN_ORDER_VALUE=99
MAX_ORDER_VALUE=50000

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Logging
LOG_LEVEL=info
