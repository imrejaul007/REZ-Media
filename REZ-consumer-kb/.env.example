# Consumer Knowledge Base Service Environment Variables

# Server Configuration
PORT=4010
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez-consumer-kb

# Redis Configuration (for caching and real-time updates)
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-jwt-secret-change-in-production

# Internal Service Communication
INTERNAL_SERVICE_TOKENS_JSON={"intent-graph":"token","payment":"token","order":"token"}

# Intent Graph Service URL
INTENT_GRAPH_SERVICE_URL=http://localhost:4008

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
