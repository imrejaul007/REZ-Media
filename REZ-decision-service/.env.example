# rez-decision-service Environment Variables
# Copy this file to .env.local for local development

# ===========================================
# Core Configuration
# ===========================================
NODE_ENV=development
PORT=4027

# ===========================================
# REZ-Intelligence Integration
# ===========================================

# REZ-Intent-Graph URL (for user segment evaluation)
INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com

# REZ-Event-Platform URL (for analytics events)
EVENT_PLATFORM_URL=https://rez-event-platform.onrender.com

# REZ-Intelligence Hub URL (for ML targeting models)
INTELLIGENCE_HUB_URL=https://rez-intelligence-hub.onrender.com

# REZ-Insights Service URL (for real-time analytics)
INSIGHTS_SERVICE_URL=https://rez-insights-service.onrender.com

# ===========================================
# Authentication
# ===========================================

# CRITICAL: All services MUST use the SAME token for inter-service communication
# Generate with: openssl rand -hex 32
# This token must match across:
#   - REZ-Media (REZ-ads-service, REZ-decision-service, etc.)
#   - REZ-Intelligence (REZ-intent-graph, REZ-event-platform, etc.)
INTERNAL_SERVICE_TOKENS_JSON={"decision-service":"your-shared-secret-token"}
INTERNAL_SERVICE_TOKEN=your-shared-secret-token

# JWT secret for admin/user authentication
JWT_SECRET=your-jwt-secret

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=10

# ===========================================
# Phase 3-5 Engine Flags
# ===========================================
SAMPLING_ENGINE_ENABLED=true
ATTRIBUTION_ENGINE_ENABLED=true
DYNAMIC_PRICING_ENABLED=true
AUTO_CAMPAIGN_ENABLED=true
SMART_COIN_ALLOCATION_ENABLED=true
AUTO_COIN_DISTRIBUTION_ENABLED=true
MERCHANT_COIN_ANALYTICS_ENABLED=true
DOOH_ANALYTICS_ENABLED=true

# ===========================================
# Performance Tuning
# ===========================================
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000
CIRCUIT_BREAKER_ENABLED=false

# ===========================================
# CORS Configuration
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://rez.money

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=debug
ENABLE_DEBUG_ENDPOINTS=true

# ===========================================
# BullMQ Queues
# ===========================================
# Shared queues for async processing
MEDIA_EVENTS_QUEUE=media-events
NOTIFICATION_QUEUE=notification-events
