# AI Campaign Builder - Environment Variables

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

INTERNAL_SERVICE_TOKEN=your-secure-random-token-here
INTERNAL_SERVICE_TOKENS_JSON={"campaign-service":"token1","ads-service":"token2"}

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

PORT=4009
NODE_ENV=development

# OpenAI API Key (Optional)
# Get your key from: https://platform.openai.com/api-keys
# If not set, the service will use simulated responses (rule-based fallback)
OPENAI_API_KEY=sk-...

# =============================================================================
# SECURITY NOTES
# =============================================================================
# Generate token: openssl rand -hex 32
