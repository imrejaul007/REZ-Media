# Economic Engine - Environment Variables

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

INTERNAL_SERVICE_TOKEN=your-secure-random-token-here
INTERNAL_SERVICE_TOKENS_JSON={"pricing-service":"token1","inventory-service":"token2"}

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

PORT=4016
MONGODB_URI=mongodb://localhost:27017/rez-economic
NODE_ENV=development

# =============================================================================
# SECURITY NOTES
# =============================================================================
# Generate token: openssl rand -hex 32
