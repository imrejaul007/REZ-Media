# Engagement Platform - Environment Variables

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

INTERNAL_SERVICE_TOKEN=your-secure-random-token-here
INTERNAL_SERVICE_TOKENS_JSON={"loyalty-service":"token1","offer-service":"token2"}

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

PORT=4017
MONGODB_URI=mongodb://localhost:27017/rez-engagement
NODE_ENV=development

# =============================================================================
# SECURITY NOTES
# =============================================================================
# Generate token: openssl rand -hex 32
