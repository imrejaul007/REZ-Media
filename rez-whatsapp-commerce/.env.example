# REZ WhatsApp Commerce Service - Environment Variables

# Server Configuration
PORT=4031
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez-whatsapp-commerce
MONGODB_USER=
MONGODB_PASSWORD=

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# WhatsApp Business API Configuration
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-facebook-business-account-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_API_VERSION=v18.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# Internal Service Tokens (JSON map)
INTERNAL_SERVICE_TOKENS_JSON={"menu-service":"token1","inventory-service":"token2"}

# External Service URLs
MENU_SERVICE_URL=http://localhost:4030
INVENTORY_SERVICE_URL=http://localhost:3000
PRICE_SERVICE_URL=http://localhost:3001

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Caching TTL (in seconds)
CACHE_TTL_PRODUCTS=300
CACHE_TTL_CATEGORIES=3600
CACHE_TTL_SEARCH=60
CACHE_TTL_RECOMMENDATIONS=900
CACHE_TTL_STOCK=30

# WhatsApp Catalog Settings
WHATSAPP_CATALOG_SYNC_INTERVAL=3600
WHATSAPP_MAX_PRODUCTS_PER_MESSAGE=10
WHATSAPP_PRODUCT_IMAGE_SIZE=800

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
