# REZ WhatsApp Commerce Service - Environment Variables

# Server Configuration
PORT=4031
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez-whatsapp-commerce
MONGODB_USER=
MONGODB_PASSWORD=

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# WhatsApp Business API Configuration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_PHONE_NUMBER=+14155238886
WHATSAPP_BUSINESS_ACCOUNT_ID=your-facebook-business-account-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# Razorpay Configuration
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# REZ Wallet Service Integration
WALLET_SERVICE_URL=http://localhost:4002
WALLET_SERVICE_TOKEN=your-wallet-service-internal-token

# Internal Service Tokens (JSON map of service-name:token)
INTERNAL_SERVICE_TOKENS_JSON={"menu-service":"token1","inventory-service":"token2","payment-service":"token3"}

# External Service URLs
MENU_SERVICE_URL=http://localhost:4030
INVENTORY_SERVICE_URL=http://localhost:3000
PRICE_SERVICE_URL=http://localhost:3001
ORDER_SERVICE_URL=http://localhost:4001

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Caching TTL (in seconds)
CACHE_TTL_PRODUCTS=300
CACHE_TTL_CATEGORIES=3600
CACHE_TTL_SEARCH=60
CACHE_TTL_RECOMMENDATIONS=900
CACHE_TTL_STOCK=30

# WhatsApp Catalog Settings
WHATSAPP_CATALOG_SYNC_INTERVAL=3600
WHATSAPP_MAX_PRODUCTS_PER_MESSAGE=10
WHATSAPP_PRODUCT_IMAGE_SIZE=800

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
