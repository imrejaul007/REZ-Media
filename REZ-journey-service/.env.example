# Journey Service - Environment Variables

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

INTERNAL_SERVICE_TOKEN=your-secure-random-token-here
INTERNAL_SERVICE_TOKENS_JSON={"user-service":"token1","campaign-service":"token2"}

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

PORT=4019
MONGODB_URI=mongodb://localhost:27017/rez-journey
NODE_ENV=development

# =============================================================================
# SECURITY NOTES
# =============================================================================
# Generate token: openssl rand -hex 32
