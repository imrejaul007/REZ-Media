# ============================================
# Voice Cart Recovery Service
# ============================================

# Server Configuration
PORT=4053
NODE_ENV=development
LOG_LEVEL=info

# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# Webhook URL (must be publicly accessible for Twilio)
VOICE_WEBHOOK_URL=https://your-domain.com

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez-voice-cart-recovery
MONGODB_DB_NAME=rez-voice-cart-recovery

# Redis Configuration (optional - for campaign queue)
REDIS_URL=redis://localhost:6379

# Service URLs (for internal service communication)
AUTOMATION_SERVICE_URL=http://localhost:4028
LEAD_INTELLIGENCE_URL=http://localhost:3000
ORDER_SERVICE_URL=http://localhost:4003
UNIFIED_CHAT_URL=http://localhost:3000

# Security
INTERNAL_SERVICE_TOKEN=your-secure-internal-token

# CORS
CORS_ORIGIN=*

# Human Agent Transfer Number
HUMAN_AGENT_NUMBER=+15551234567

# Optional: Sentry DSN for error tracking
# SENTRY_DSN=https://xxx@sentry.io/xxx
