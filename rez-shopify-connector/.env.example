# Shopify Connector Service Configuration
# Copy this file to .env and fill in your values

# Server
PORT=4050
NODE_ENV=development

# Shopify Partner App Credentials
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret
SHOPIFY_REDIRECT_URI=http://localhost:4050/api/shopify/callback
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_customers,read_inventory,write_inventory

# Database
MONGODB_URI=mongodb://localhost:27017/shopify-connector

# Redis
REDIS_URL=redis://localhost:6379

# Security
INTERNAL_SERVICE_TOKEN=your-secure-internal-token

# ReZ Platform Services
REZ_CATALOG_SERVICE_URL=http://localhost:3000
REZ_ORDER_SERVICE_URL=http://localhost:4003
REZ_IDENTITY_SERVICE_URL=http://localhost:4001
REZ_INVENTORY_SERVICE_URL=http://localhost:4010

# Observability
SENTRY_DSN=https://xxx@sentry.io/xxx
SERVICE_VERSION=1.0.0

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
